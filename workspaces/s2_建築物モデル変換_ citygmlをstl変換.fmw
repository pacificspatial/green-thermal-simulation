MACRO OUTPUT_INSTANCE_FTYPE not_selected
Lookup $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter_RouterTable   ""  "not_selected"   fme_surface $(OUTPUT_SURFACE_FTYPE)
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter_4f906df5_3156_407a_91a5_4762fc8e8eee5} ]
MACRO COLLECTION_HANDLING NOT_THIS_TIME
MACRO INSTANCE_FILTERING *
INCLUDE [    if 0 {       puts "MACRO COLLECTION_HANDLING *";       if <Unused> {          puts "MACRO INSTANCE_FILTERING NOT_THIS_TIME";       };    };    if {{$(OUTPUT_INSTANCE_FTYPE)} == "not_selected"} {       puts "MACRO INSTANCE_FILTERING NOT_THIS_TIME";    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter_InputPassThrough }    INPUT  FEATURE_TYPE "$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_AggregateFilter_NOT_AGGREGATE"    OUTPUT { FEATURE_TYPE $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter___Input___       @Geometry(FIX_FMETYPE_FMEGEOMETRY) }
FACTORY_DEF {$(INSTANCE_FILTERING)} TestFactory    FACTORY_NAME { $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter_InstanceTest }    INPUT { FEATURE_TYPE $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter___Input___ }    TEST @Geometry(IS_GEOMETRY_INSTANCE) == 1    OUTPUT { PASSED FEATURE_TYPE $(OUTPUT_INSTANCE_FTYPE) }    OUTPUT { FAILED FEATURE_TYPE $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter___Input___ }
FACTORY_DEF {$(COLLECTION_HANDLING)} TestFactory    FACTORY_NAME { $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter_CollectionTest }    INPUT { FEATURE_TYPE $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter___Input___ }    TEST &fme_type == "fme_collection"    OUTPUT { FAILED FEATURE_TYPE $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter___Not_Collection___ }    OUTPUT { PASSED FEATURE_TYPE $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter___Collection___ }
FACTORY_DEF {$(COLLECTION_HANDLING)} DeaggregateFactory    FACTORY_NAME { $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter_Deagg }    INPUT { FEATURE_TYPE $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter___Collection___ }    HOMOGENIZE_COLLECTIONS YES    RECURSIVE YES    SET_FME_TYPE YES    INSTANTIATE_GEOMETRY_INSTANCES_NEW { <Unused> }    OUTPUT { POINT FEATURE_TYPE $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter___HomogeneousAggregate___ }    OUTPUT { LINE FEATURE_TYPE $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter___HomogeneousAggregate___ }    OUTPUT { POLYGON FEATURE_TYPE $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter___HomogeneousAggregate___ }    OUTPUT { DONUT FEATURE_TYPE $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter___HomogeneousAggregate___ }    OUTPUT { AGGREGATE FEATURE_TYPE $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter___HomogeneousAggregate___ }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter_RouterPrepper }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT { FEATURE_TYPE $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter___HomogeneousAggregate___ }    INPUT { FEATURE_TYPE $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter___Not_Collection___ }    INPUT { FEATURE_TYPE $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter___Input___ }    OUTPUT { FEATURE_TYPE $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter___Prepped___        @Lookup($(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter_RouterTable,fme_type,ENCODED_ATTR,$(FME_UUID_SAFE)_targetFeatureType) }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter_Router }    INPUT { FEATURE_TYPE $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter___Prepped___ }    TEST { @Value($(FME_UUID_SAFE)_targetFeatureType) != "not_selected" }    OUTPUT { PASSED FEATURE_TYPE * @FeatureType(@Value($(FME_UUID_SAFE)_targetFeatureType))                                 @RemoveAttributes($(FME_UUID_SAFE)_targetFeatureType) }    OUTPUT { FAILED FEATURE_TYPE "$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_GeometryFilter_<UNFILTERED>"        @RemoveAttributes($(FME_UUID_SAFE)_targetFeatureType)         }
