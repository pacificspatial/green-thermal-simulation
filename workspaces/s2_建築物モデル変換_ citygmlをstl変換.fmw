# Because @Count itself will evalute the expression to calculate the
# domain, we don't need to do anything in Tcl per feature going by
INCLUDE [    set domainPrefix {};    if { {Local} == {Local} }    {       set domainPrefix [FME_EncodeText {$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Counter_2_}];    };    puts "MACRO $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Counter_2_FULL_DOMAIN ${domainPrefix}counter_part_id"; ]
