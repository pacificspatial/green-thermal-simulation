FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_AttributeCreator    INPUT  FEATURE_TYPE "$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_BoundsExtractor_OUTPUT"    MULTI_FEATURE_MODE NO    NULL_ATTR_MODE NO_OP     ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV     ATTR_ACTION { "" "__ssc.elevation" "SET_TO" "$($(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_ELEVATION$encode)" }      ATTR_ACTION { "" "__ssc.flag" "SET_TO" "FME_CONDITIONAL:DEFAULT_VALUE'0'BOOL_OP;OR;COMPOSITE_TEST;<Unused>;TEST $($(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_ELEVATION$encode) < <at>Value<openparen>__ssc.zmin<closeparen>'-1'BOOL_OP;OR;COMPOSITE_TEST;<Unused>;TEST <at>Value<openparen>__ssc.zmax<closeparen> < $($(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_ELEVATION$encode)'1'FME_NUM_CONDITIONS3___" }    OUTPUT OUTPUT FEATURE_TYPE "$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_AttributeCreator_OUTPUT"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Tester }    INPUT  FEATURE_TYPE "$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_AttributeCreator_OUTPUT"    TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>__ssc.flag<closeparen>,$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Tester)" != 0 ENCODED }    BOOLEAN_OPERATOR  { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    OUTPUT { PASSED FEATURE_TYPE "$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Tester_PASSED"         }    OUTPUT { FAILED FEATURE_TYPE "$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Tester_FAILED"         }
# -------------------------------------------------------------------------
# Create the DomainName that this transformer will use.
# Because @Count itself will evalute the expression to calculate the
# domain, we don't need to do anything in Tcl per feature going by
INCLUDE [    set domainPrefix {};    if { {Local} == {Local} }    {       set domainPrefix [FME_EncodeText {$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Counter_}];    };    puts "MACRO $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Counter_FULL_DOMAIN ${domainPrefix}counter_id"; ]
FACTORY_DEF {*} ExecuteFunctionFactory    FACTORY_NAME { $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Counter_Rejector }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Tester_PASSED"    FUNCTION_DEFINITION { @Count(REJECTABLE,fme_encoded,$($(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Counter_FULL_DOMAIN),"0") }    RESULT_ATTRIBUTE { "__ssc.id" }    OUTPUT { COMPLETE FEATURE_TYPE "$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Counter_OUTPUT"        }    OUTPUT { REJECTED FEATURE_TYPE "$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Counter_<REJECTED>"        }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Counter OUTPUT Splitter"   INPUT FEATURE_TYPE "$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Counter_OUTPUT"   OUTPUT FEATURE_TYPE "$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Counter_OUTPUT_0_PHCKQIlPDyI="   OUTPUT FEATURE_TYPE "$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Counter_OUTPUT_1_ucbUp1Leoew="
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Tester_2 }    INPUT  FEATURE_TYPE "$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Counter_OUTPUT_0_PHCKQIlPDyI="    TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>__ssc.flag<closeparen>,$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Tester_2)" < 0 ENCODED }    BOOLEAN_OPERATOR  { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    OUTPUT { PASSED FEATURE_TYPE "$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Tester_2_PASSED"         }    OUTPUT { FAILED FEATURE_TYPE "$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Tester_2_FAILED"         }
