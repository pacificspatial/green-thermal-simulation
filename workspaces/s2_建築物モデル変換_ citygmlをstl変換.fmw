INCLUDE [    if { ({REVERSE} == {REVERSE}) } {       puts {MACRO ORIENT_FUNC @Orient(REVERSE, REVERSE_ALL,  FLIP_APPEARANCES)}    } else {       puts {MACRO ORIENT_FUNC @Orient(REVERSE)}    } ]
