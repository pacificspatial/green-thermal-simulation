# Create the DomainName that this transformer will use.
# Because @Count itself will evalute the expression to calculate the
# domain, we don't need to do anything in Tcl per feature going by
INCLUDE [    set domainPrefix {};    if { {Local} == {Local} }    {       set domainPrefix [FME_EncodeText {$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Counter_2_}];    };    puts "MACRO $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Counter_2_FULL_DOMAIN ${domainPrefix}counter_part_id"; ]
FACTORY_DEF {*} ExecuteFunctionFactory    FACTORY_NAME { $(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Counter_2_Rejector }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_LineJoiner_LINE"    FUNCTION_DEFINITION { @Count(REJECTABLE,fme_encoded,$($(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Counter_2_FULL_DOMAIN),"0") }    RESULT_ATTRIBUTE { "__ssc.part_id" }    OUTPUT { COMPLETE FEATURE_TYPE "$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Counter_2_OUTPUT"        }    OUTPUT { REJECTED FEATURE_TYPE "$(BRepSolidBoundaryCreator.Beta_WORKSPACE_NAME)_Counter_2_<REJECTED>"        }
