MACRO CsmapReprojector_TRANSFORMATION
# Only pass on transformation if a source coordinate system was picked
INCLUDE [    if { {EPSG:6668} != {} } {       puts {MACRO CsmapReprojector_TRANSFORMATION };    }; ]
FACTORY_DEF {*} ReprojectFactory    FACTORY_NAME { CsmapReprojector }    INPUT  FEATURE_TYPE parsed_OGCGEOPACKAGE_1    ENGINE { ENGINE_NAME FME         SOURCE "EPSG:6668"         DESTINATION "@EvaluateExpression(FDIV,STRING,$(DEST_COORDSYS),CsmapReprojector)"         VERTICAL_HANDLING <Unused>         GEOID_HEIGHT_GRID "<Unused>"         TRANSFORMATION "$(CsmapReprojector_TRANSFORMATION)" }    INTERPOLATION_TYPE { NearestNeighbor }    RASTER_CELL_SIZE { PreserveCells }    RASTER_TOLERANCE { 0.0 }    OUTPUT { REPROJECTED FEATURE_TYPE CsmapReprojector_REPROJECTED          }    OUTPUT { REJECTED FEATURE_TYPE CsmapReprojector_<REJECTED>          }
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
